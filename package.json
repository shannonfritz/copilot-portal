{
	"name": "copilot-portal",
	"description": "Mobile-friendly web portal for GitHub Copilot CLI — share a session across any device",
	"version": "0.2.0",
	"type": "module",
	"engines": {
		"node": ">=22.5.0"
	},
	"main": "./dist/server.js",
	"scripts": {
		"build": "node esbuild.cjs --production && cd webui && npm run build",
		"build:ext": "node esbuild.cjs",
		"build:ui": "cd webui && npm run build",
		"start": "node dist/server.js",
		"dev": "node esbuild.cjs --watch",
		"watch:ui": "cd webui && npm run dev",
		"test": "node tools/test-client.mjs",
		"postinstall": "patch-package"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/qrcode": "^1.5.5",
		"@types/ws": "^8.5.14",
		"esbuild": "^0.25.0",
		"patch-package": "^8.0.1",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"@github/copilot-sdk": "^0.1.32",
		"qrcode": "^1.5.4",
		"ws": "^8.18.0"
	}
}
